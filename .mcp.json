{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "flutter-inspector": {
      "command": "${MCP_FLUTTER_BIN:-$HOME/tools/flutter_inspector_mcp}",
      "args": [
        "--dart-vm-host=localhost",
        "--dart-vm-port=8181",
        "--resources",
        "--images",
        "--dynamics"
      ]
    }
  }
}
